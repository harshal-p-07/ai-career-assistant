# ============================================================
#  .env — copy this to .env and fill in your keys
#  To switch provider: change GROQ_MODEL or OPENROUTER_MODEL
#  To switch which feature uses which provider: edit config/ai.config.js
# ============================================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai-career-assistant
JWT_SECRET=your_jwt_secret_here

# ── AI Providers (add at least one) ───────────────────────
# Groq — fast, free: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Other Groq models: llama-3.1-8b-instant  mixtral-8x7b-32768

# OpenRouter — free models: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Other free models: google/gemma-3-27b-it:free  mistralai/mistral-7b-instruct:free

# ── Web Search (optional but enables Step 1 research) ─────
# Serper — 100 free searches/month: https://serper.dev
SERPER_API_KEY=your_serper_key_here

# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
